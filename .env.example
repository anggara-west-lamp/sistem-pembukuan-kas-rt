APP_PORT=8080
APP_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=kasrt
DB_SSLMODE=disable

# JWT
JWT_SECRET=change-me-super-secret
JWT_TTL_MINUTES=60

# MinIO / S3 compatible
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_USE_SSL=false
STORAGE_BUCKET=kasrt-proof

